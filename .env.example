# Database
DATABASE_URL="postgresql://user:password@host:port/database"

# Redis
REDIS_URL="redis://default:password@host:port"

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-random-64-byte-hex"
JWT_EXPIRES_IN="7d"

# SMTP Mailer (Maileroo)
SMTP_HOST="smtp.maileroo.com"
SMTP_PORT="587"
SMTP_USER="noreply@yourdomain.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@yourdomain.com"

# WhatsApp Wavo (optional)
WAVO_API_KEY=""
WAVO_SERVICE_ID=""

# Server
PORT=4000
NODE_ENV=development

# Frontend URL (for email links, logo, etc.)
FRONTEND_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"
GOOGLE_REDIRECT_URI="http://localhost:4000/api/auth/google/callback"

TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxxxxxx

# AI Provider Keys (optional)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
DEEPSEEK_KEY_1=""
DEEPSEEK_KEY_2=""
DEEPSEEK_KEY_3=""
GROQ_KEY_1=""
GROQ_KEY_2=""
GROQ_KEY_3=""
OPENROUTER_KEY_1=""
OPENROUTER_KEY_2=""
OPENROUTER_KEY_3=""
